# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# Jupyter
.ipynb_checkpoints/
*.ipynb_meta

# Data — audio, transcripts, and outputs are not committed
data/audio/*
!data/audio/.gitkeep
data/transcripts/*
!data/transcripts/.gitkeep
data/processed/*
!data/processed/.gitkeep
outputs/*
!outputs/.gitkeep

# Models — downloaded or fine-tuned artifacts
models/*
!models/.gitkeep

# Secrets and config overrides
.env
*.env.local
config/secrets.yaml

# HuggingFace cache (large model files)
.cache/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Logs
*.log
logs/
